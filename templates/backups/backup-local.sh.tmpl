#!/bin/bash

set -Eeuo pipefail

SERVER_NAME="{{SERVER_NAME}}"
DATA_ROOT="{{DATA_ROOT}}"
BACKUP_ROOT="{{BACKUP_DIR}}"
STAMP="$(date +%Y%m%d_%H%M%S)"
RUN_DIR="${BACKUP_ROOT}/fayaasrv_${SERVER_NAME}_${STAMP}"
RETENTION_DAYS=14

mkdir -p "${RUN_DIR}"

archive_dir() {
    local source_dir="$1"
    local name="$2"

    if [[ -d "${source_dir}" ]]; then
        tar -czf "${RUN_DIR}/${name}.tar.gz" -C "$(dirname "${source_dir}")" "$(basename "${source_dir}")"
    fi
}

archive_dir "${DATA_ROOT}/docker" "docker"
archive_dir "${DATA_ROOT}/data" "data"
archive_dir "${DATA_ROOT}/MDs" "docs"

if docker ps --format '{{.Names}}' | grep -qx postgres; then
    docker exec postgres pg_dumpall -U postgres | gzip > "${RUN_DIR}/postgres.sql.gz"
fi

printf 'server=%s\ncreated=%s\n' "${SERVER_NAME}" "${STAMP}" > "${RUN_DIR}/manifest.txt"

find "${BACKUP_ROOT}" -maxdepth 1 -type d -name 'fayaasrv_*' -mtime +"${RETENTION_DAYS}" -exec rm -rf {} +

printf 'Backup complete: %s\n' "${RUN_DIR}"
