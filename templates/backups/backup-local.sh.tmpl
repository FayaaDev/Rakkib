#!/bin/bash
# Local backup script (v2 - archive creation & retention only, no cloud upload)
# Creates scoped backup artifacts and manages local retention

set -Eeuo pipefail

BACKUP_ROOT="{{DATA_ROOT}}/backups"
DATE="$(date +%Y%m%d_%H%M%S)"
RUN_NAME="infra-backup_${DATE}"
RUN_DIR="${BACKUP_ROOT}/${RUN_NAME}"
WORK_DIR="${RUN_DIR}/.work"

HOST_SOURCE="${WORK_DIR}/host"
DOCKER_SOURCE="${WORK_DIR}/docker-config"
OPERATOR_SOURCE="${WORK_DIR}/operator"

HOST_ARCHIVE="${RUN_DIR}/host/host_definition_${DATE}.tar.gz"
DOCKER_ARCHIVE="${RUN_DIR}/docker-config/docker_config_${DATE}.tar.gz"
OPERATOR_ARCHIVE="${RUN_DIR}/operator/operator_config_${DATE}.tar.gz"
DATA_ARCHIVE="${RUN_DIR}/data/persistent_runtime_state_${DATE}.tar.gz"
POSTGRES_BACKUP="${RUN_DIR}/postgres/postgres_full_${DATE}.sql.gz"
MANIFEST_FILE="${RUN_DIR}/metadata/backup-manifest.txt"
CHECKSUM_FILE="${RUN_DIR}/metadata/checksums.sha256"
VERSIONS_FILE="${RUN_DIR}/metadata/versions.txt"

DATA_INCLUDE_DIRS=(
    cloudflared
    caddy
    changedetection
    changedetection-mcp
    gdrive
    lightrag
    n8n
    nocodb
    opencode
    seharadar
    superset
    telegram-bot-api
    vazhs-backend
)

DATA_EXCLUDE_DIRS=(
    postgres
    mattermost
    fayaameet
    adguard
)

CLEANUP_RETENTION_DAYS=30
SUCCESS=0

log_section() {
    echo ""
    echo "$1"
    echo "-----------------------------------"
}

log_info() {
    echo "[info] $1"
}

log_warn() {
    echo "[warn] $1"
}

cleanup() {
    if [[ "${SUCCESS}" -eq 1 ]]; then
        rm -rf "${RUN_DIR}"
        echo ""
        echo "[cleanup] Removed local run directory: ${RUN_DIR}"
    else
        echo ""
        echo "[cleanup] Preserved failed run directory: ${RUN_DIR}"
    fi
}

trap cleanup EXIT

array_contains() {
    local needle="$1"
    shift
    local item

    for item in "$@"; do
        if [[ "${item}" == "${needle}" ]]; then
            return 0
        fi
    done

    return 1
}

copy_path_if_exists() {
    local source_path="$1"
    local dest_path="$2"

    if [[ -e "${source_path}" ]]; then
        mkdir -p "$(dirname "${dest_path}")"
        cp -a "${source_path}" "${dest_path}"
    fi
}

sudo_copy_path_if_exists() {
    local source_path="$1"
    local dest_path="$2"

    if sudo test -e "${source_path}"; then
        mkdir -p "$(dirname "${dest_path}")"
        sudo cp -a "${source_path}" "${dest_path}"
        sudo find "${dest_path}" -exec chown -h "$(id -u):$(id -g)" {} +
    fi
}

create_run_layout() {
    mkdir -p \
        "${RUN_DIR}/host" \
        "${RUN_DIR}/docker-config" \
        "${RUN_DIR}/operator" \
        "${RUN_DIR}/data" \
        "${RUN_DIR}/postgres" \
        "${RUN_DIR}/metadata" \
        "${HOST_SOURCE}" \
        "${DOCKER_SOURCE}" \
        "${OPERATOR_SOURCE}"
}

collect_host_definition() {
    local service_file

    mkdir -p \
        "${HOST_SOURCE}/systemd/system" \
        "${HOST_SOURCE}/user-systemd" \
        "${HOST_SOURCE}/crontab" \
        "${HOST_SOURCE}/firewall" \
        "${HOST_SOURCE}/package-manifest" \
        "${HOST_SOURCE}/enabled-services"

    shopt -s nullglob
    for service_file in /etc/systemd/system/*.service; do
        sudo cp -a "${service_file}" "${HOST_SOURCE}/systemd/system/"
    done
    for service_file in /home/{{ADMIN_USER}}/.config/systemd/user/*.service*; do
        cp -a "${service_file}" "${HOST_SOURCE}/user-systemd/"
    done
    shopt -u nullglob

    sudo find "${HOST_SOURCE}/systemd" -exec chown -h "$(id -u):$(id -g)" {} +

    sudo_copy_path_if_exists "/etc/ssh" "${HOST_SOURCE}/ssh"
    sudo_copy_path_if_exists "/etc/ufw" "${HOST_SOURCE}/ufw"
    sudo_copy_path_if_exists "/etc/hostname" "${HOST_SOURCE}/hostname"
    sudo_copy_path_if_exists "/etc/hosts" "${HOST_SOURCE}/hosts"

    if crontab -l > "${HOST_SOURCE}/crontab/user.crontab" 2>/dev/null; then
        :
    else
        printf '# No user crontab configured\n' > "${HOST_SOURCE}/crontab/user.crontab"
    fi

    if command -v iptables-save >/dev/null 2>&1; then
        sudo iptables-save > "${HOST_SOURCE}/firewall/iptables.rules"
    else
        printf '# iptables-save not available\n' > "${HOST_SOURCE}/firewall/iptables.rules"
    fi

    if command -v dpkg >/dev/null 2>&1; then
        dpkg --get-selections > "${HOST_SOURCE}/package-manifest/dpkg-selections.txt"
    else
        printf '# dpkg not available\n' > "${HOST_SOURCE}/package-manifest/dpkg-selections.txt"
    fi

    if command -v systemctl >/dev/null 2>&1; then
        if systemctl list-unit-files --type=service --state=enabled > "${HOST_SOURCE}/enabled-services/system.txt"; then
            :
        else
            printf '# unable to list enabled system services\n' > "${HOST_SOURCE}/enabled-services/system.txt"
        fi

        if systemctl --user list-unit-files --type=service --state=enabled > "${HOST_SOURCE}/enabled-services/user.txt" 2>/dev/null; then
            :
        else
            printf '# unable to list enabled user services\n' > "${HOST_SOURCE}/enabled-services/user.txt"
        fi
    else
        printf '# systemctl not available\n' > "${HOST_SOURCE}/enabled-services/system.txt"
        printf '# systemctl --user not available\n' > "${HOST_SOURCE}/enabled-services/user.txt"
    fi

    tar -czf "${HOST_ARCHIVE}" -C "${WORK_DIR}" host
    log_info "Host definition archive: $(du -h "${HOST_ARCHIVE}" | cut -f1)"
}

collect_docker_config() {
    local source_file
    local relative_path
    local dest_path
    local docker_file_count=0

    while IFS= read -r -d '' source_file; do
        relative_path="${source_file#{{DATA_ROOT}}/docker/}"

        if ! should_include_docker_file "${relative_path}"; then
            continue
        fi

        dest_path="${DOCKER_SOURCE}/${relative_path}"
        mkdir -p "$(dirname "${dest_path}")"
        cp -a "${source_file}" "${dest_path}"
        docker_file_count=$((docker_file_count + 1))
    done < <(
        find {{DATA_ROOT}}/docker \
            \( -type d \( -name node_modules -o -name .git -o -name .ruff_cache -o -name dist -o -name build -o -name .next -o -name coverage \) -prune \) -o \
            \( -type f -print0 \)
    )

    tar -czf "${DOCKER_ARCHIVE}" -C "${WORK_DIR}" docker-config
    log_info "Docker config archive: $(du -h "${DOCKER_ARCHIVE}" | cut -f1) (${docker_file_count} files)"
}

should_include_docker_file() {
    local relative_path="$1"
    local base_name="${relative_path##*/}"

    case "${base_name}" in
        docker-compose.yml|docker-compose.yaml|compose.yml|compose.yaml|.env|.env.*|Dockerfile|Dockerfile.*|Caddyfile)
            return 0
            ;;
        *.conf)
            return 0
            ;;
        *.toml)
            case "${base_name}" in
                pyproject.toml|bunfig.toml|railway.toml)
                    return 1
                    ;;
            esac

            if [[ "${relative_path}" == */config/* ]] || [[ "${relative_path}" == */configs/* ]] || [[ "${relative_path}" != */*/* ]]; then
                return 0
            fi

            return 1
            ;;
        *.json)
            case "${base_name}" in
                package.json|package-lock.json|tsconfig*.json|manifest.json|components.json|app.json|extensions.json|settings.json|*.meta.json|*_snapshot.json|_journal.json)
                    return 1
                    ;;
            esac

            if [[ "${relative_path}" == */config/* ]] || [[ "${relative_path}" == */configs/* ]] || [[ "${base_name}" == *config*.json ]]; then
                return 0
            fi

            return 1
            ;;
    esac

    return 1
}

collect_operator_config() {
    local shell_file
    local script_path
    local script_name
    local first_line
    local script_count=0

    copy_path_if_exists "/home/{{ADMIN_USER}}/.ssh" "${OPERATOR_SOURCE}/ssh"
    copy_path_if_exists "/home/{{ADMIN_USER}}/.config/systemd" "${OPERATOR_SOURCE}/systemd"
    copy_path_if_exists "/home/{{ADMIN_USER}}/.config/opencode" "${OPERATOR_SOURCE}/opencode-config"
    copy_path_if_exists "/home/{{ADMIN_USER}}/.agents" "${OPERATOR_SOURCE}/agents"
    copy_path_if_exists "/home/{{ADMIN_USER}}/.opencode" "${OPERATOR_SOURCE}/opencode-state"
    copy_path_if_exists "/home/{{ADMIN_USER}}/.openclaw" "${OPERATOR_SOURCE}/openclaw"
    copy_path_if_exists "/home/{{ADMIN_USER}}/.gnupg" "${OPERATOR_SOURCE}/gnupg"

    mkdir -p "${OPERATOR_SOURCE}/shell" "${OPERATOR_SOURCE}/scripts"

    for shell_file in .gitconfig .bashrc .zshrc .zprofile .profile; do
        copy_path_if_exists "/home/{{ADMIN_USER}}/${shell_file}" "${OPERATOR_SOURCE}/shell/${shell_file}"
    done

    shopt -s nullglob
    for script_path in /home/{{ADMIN_USER}}/.local/bin/*; do
        [[ -f "${script_path}" ]] || continue
        script_name="$(basename "${script_path}")"

        if [[ "${script_name}" == *.sh ]]; then
            cp -a "${script_path}" "${OPERATOR_SOURCE}/scripts/${script_name}"
            script_count=$((script_count + 1))
            continue
        fi

        if [[ "${script_name}" != *.* ]] && [[ -x "${script_path}" ]]; then
            IFS= read -r first_line < "${script_path}" || first_line=""
            if [[ "${first_line}" == '#!'* ]]; then
                cp -a "${script_path}" "${OPERATOR_SOURCE}/scripts/${script_name}"
                script_count=$((script_count + 1))
            fi
        fi
    done
    shopt -u nullglob

    tar -czf "${OPERATOR_ARCHIVE}" -C "${WORK_DIR}" operator
    log_info "Operator config archive: $(du -h "${OPERATOR_ARCHIVE}" | cut -f1) (${script_count} scripts)"
}

scan_unknown_data_dirs() {
    local data_dir
    local dir_name

    shopt -s nullglob
    for data_dir in {{DATA_ROOT}}/data/*; do
        [[ -d "${data_dir}" ]] || continue
        dir_name="$(basename "${data_dir}")"

        if array_contains "${dir_name}" "${DATA_INCLUDE_DIRS[@]}"; then
            continue
        fi

        if array_contains "${dir_name}" "${DATA_EXCLUDE_DIRS[@]}"; then
            continue
        fi

        log_warn "Unknown {{DATA_ROOT}}/data directory is not in backup policy: ${dir_name}"
    done
    shopt -u nullglob
}

collect_persistent_data() {
    local existing_data_dirs=()
    local dir_name

    scan_unknown_data_dirs

    for dir_name in "${DATA_INCLUDE_DIRS[@]}"; do
        if [[ -d "{{DATA_ROOT}}/data/${dir_name}" ]]; then
            existing_data_dirs+=("${dir_name}")
        fi
    done

    if [[ "${#existing_data_dirs[@]}" -eq 0 ]]; then
        log_warn "No configured {{DATA_ROOT}}/data directories exist; creating an empty archive is skipped"
        return
    fi

    sudo tar -czf "${DATA_ARCHIVE}" -C {{DATA_ROOT}}/data "${existing_data_dirs[@]}"
    sudo chown "$(id -u):$(id -g)" "${DATA_ARCHIVE}"
    log_info "Persistent runtime archive: $(du -h "${DATA_ARCHIVE}" | cut -f1)"
}

collect_postgres_dump() {
    docker exec postgres pg_dumpall -U postgres | gzip > "${POSTGRES_BACKUP}"
    log_info "Postgres dump: $(du -h "${POSTGRES_BACKUP}" | cut -f1)"
}

write_versions_metadata() {
    local docker_version="unavailable"
    local docker_compose_version="unavailable"

    if command -v docker >/dev/null 2>&1; then
        docker_version="$(docker --version 2>/dev/null || echo unavailable)"
        docker_compose_version="$(docker compose version 2>/dev/null || echo unavailable)"
    fi

    {
        echo "backup_started=$(date -Is)"
        echo "run_name=${RUN_NAME}"
        echo "script_path={{DATA_ROOT}}/backups/backup-local.sh"
        echo "backup_root=${BACKUP_ROOT}"
        echo "host={{SERVER_NAME}}"
        echo "bash_version=${BASH_VERSION}"
        echo "docker_version=${docker_version}"
        echo "docker_compose_version=${docker_compose_version}"
    } > "${VERSIONS_FILE}"
}

write_backup_manifest() {
    local dir_name

    {
        echo "Local Backup Run"
        echo "================="
        echo "Timestamp: ${DATE}"
        echo "Run directory: ${RUN_DIR}"
        echo ""
        echo "Artifacts"
        echo "---------"
        [[ -f "${HOST_ARCHIVE}" ]] && echo "host/$(basename "${HOST_ARCHIVE}")"
        [[ -f "${DOCKER_ARCHIVE}" ]] && echo "docker-config/$(basename "${DOCKER_ARCHIVE}")"
        [[ -f "${OPERATOR_ARCHIVE}" ]] && echo "operator/$(basename "${OPERATOR_ARCHIVE}")"
        [[ -f "${DATA_ARCHIVE}" ]] && echo "data/$(basename "${DATA_ARCHIVE}")"
        [[ -f "${POSTGRES_BACKUP}" ]] && echo "postgres/$(basename "${POSTGRES_BACKUP}")"
        echo "metadata/$(basename "${MANIFEST_FILE}")"
        echo "metadata/$(basename "${VERSIONS_FILE}")"
        echo "metadata/$(basename "${CHECKSUM_FILE}")"
        echo ""
        echo "Host Definition Sources"
        echo "-----------------------"
        echo "/etc/systemd/system/*.service"
        echo "/home/{{ADMIN_USER}}/.config/systemd/user/*.service*"
        echo "/etc/ssh"
        echo "/etc/ufw"
        echo "/etc/hostname"
        echo "/etc/hosts"
        echo "user crontab export"
        echo "iptables-save export"
        echo "dpkg --get-selections export"
        echo "enabled system services export"
        echo "enabled user services export"
        echo ""
        echo "Docker Config Selection"
        echo "-----------------------"
        echo "Included patterns under {{DATA_ROOT}}/docker: compose files, .env files, Dockerfiles, Caddyfile, *.conf, config-directory *.json/*.toml, and *config*.json files"
        echo "Excluded directories: node_modules, .git, .ruff_cache, dist, build, .next, coverage"
        echo ""
        echo "Operator Config Sources"
        echo "-----------------------"
        echo "/home/{{ADMIN_USER}}/.ssh"
        echo "/home/{{ADMIN_USER}}/.gitconfig"
        echo "/home/{{ADMIN_USER}}/.bashrc"
        echo "/home/{{ADMIN_USER}}/.zshrc"
        echo "/home/{{ADMIN_USER}}/.zprofile"
        echo "/home/{{ADMIN_USER}}/.profile"
        echo "/home/{{ADMIN_USER}}/.config/systemd"
        echo "/home/{{ADMIN_USER}}/.config/opencode"
        echo "/home/{{ADMIN_USER}}/.agents"
        echo "/home/{{ADMIN_USER}}/.opencode"
        echo "/home/{{ADMIN_USER}}/.openclaw"
        echo "/home/{{ADMIN_USER}}/.gnupg"
        echo "/home/{{ADMIN_USER}}/.local/bin (*.sh and shebang-based executables without extensions)"
        echo ""
        echo "Persistent Runtime Directories"
        echo "------------------------------"
        for dir_name in "${DATA_INCLUDE_DIRS[@]}"; do
            if [[ -d "{{DATA_ROOT}}/data/${dir_name}" ]]; then
                echo "{{DATA_ROOT}}/data/${dir_name}"
            fi
        done
        echo ""
        echo "Explicitly Excluded Runtime Directories"
        echo "--------------------------------------"
        for dir_name in "${DATA_EXCLUDE_DIRS[@]}"; do
            if [[ -d "{{DATA_ROOT}}/data/${dir_name}" ]]; then
                echo "{{DATA_ROOT}}/data/${dir_name}"
            fi
        done
    } > "${MANIFEST_FILE}"
}

write_checksums() {
    (
        cd "${RUN_DIR}"
        while IFS= read -r -d '' relative_file; do
            sha256sum "${relative_file}"
        done < <(
            find host docker-config operator data postgres metadata \
                -type f \
                ! -path 'metadata/checksums.sha256' \
                -print0 | sort -z
        )
    ) > "${CHECKSUM_FILE}"
}

cleanup_old_backups() {
    local backup_dir
    local cutoff_time

    cutoff_time=$(date -d "${CLEANUP_RETENTION_DAYS} days ago" +%s)

    log_section "Step 8: Cleaning Up Old Backups (retention: ${CLEANUP_RETENTION_DAYS} days)"

    shopt -s nullglob
    for backup_dir in "${BACKUP_ROOT}"/infra-backup_*; do
        [[ -d "${backup_dir}" ]] || continue

        local dir_time=$(stat -c %Y "${backup_dir}")
        if [[ ${dir_time} -lt ${cutoff_time} ]]; then
            log_info "Removing old backup: $(basename "${backup_dir}")"
            rm -rf "${backup_dir}"
        fi
    done
    shopt -u nullglob

    log_info "Cleanup complete"
}

echo "========================================"
echo "Local Infra Backup"
echo "Started: $(date)"
echo "Run: ${RUN_NAME}"
echo "========================================"

create_run_layout

log_section "Step 1: Collecting Host Definition"
collect_host_definition

log_section "Step 2: Collecting Service Definitions"
collect_docker_config

log_section "Step 3: Collecting Operator Config"
collect_operator_config

log_section "Step 4: Collecting Persistent Runtime State"
collect_persistent_data

log_section "Step 5: Dumping PostgreSQL"
collect_postgres_dump

log_section "Step 6: Writing Manifest and Checksums"
write_versions_metadata
write_backup_manifest
write_checksums
[[ -s "${CHECKSUM_FILE}" ]] || { echo "[error] Missing checksum file" >&2; exit 1; }
log_info "Metadata files created under ${RUN_DIR}/metadata"

cleanup_old_backups

SUCCESS=1

echo ""
echo "========================================"
echo "Local Infra Backup Complete"
echo "Finished: $(date)"
echo "Location: ${RUN_DIR}"
echo "========================================"
