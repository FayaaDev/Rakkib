#!/bin/bash
# Playwright Chrome Zombie Process Monitor
# Restarts playwright-chrome if too many zombie processes accumulate

ZOMBIE_THRESHOLD=5
LOG_FILE="/home/{{ADMIN_USER}}/.local/share/playwright-zombie-check.log"

# Ensure log directory exists
mkdir -p "$(dirname "$LOG_FILE")"

# Count zombie Chrome processes (grep returns non-zero if no matches, so use || echo "0")
ZOMBIE_COUNT=$(docker exec playwright-chrome ps aux 2>/dev/null | grep '\[chromium\]' | wc -l)

# Log check
echo "$(date '+%Y-%m-%d %H:%M:%S') - Zombie count: $ZOMBIE_COUNT" >> "$LOG_FILE"

# Restart if threshold exceeded
if [ "$ZOMBIE_COUNT" -gt "$ZOMBIE_THRESHOLD" ]; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') - ALERT: $ZOMBIE_COUNT zombie processes (threshold: $ZOMBIE_THRESHOLD)" >> "$LOG_FILE"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Restarting playwright-chrome..." >> "$LOG_FILE"

    docker restart playwright-chrome >> "$LOG_FILE" 2>&1

    if [ $? -eq 0 ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') - Restart completed successfully" >> "$LOG_FILE"
    else
        echo "$(date '+%Y-%m-%d %H:%M:%S') - ERROR: Restart failed" >> "$LOG_FILE"
    fi
fi

# Rotate log if too large (>1MB)
LOG_SIZE=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo "0")
if [ "$LOG_SIZE" -gt 1048576 ]; then
    mv "$LOG_FILE" "${LOG_FILE}.old"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Log rotated" >> "$LOG_FILE"
fi
