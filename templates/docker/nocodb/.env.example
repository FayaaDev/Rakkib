# NocoDB Database Connection
# Format: pg://host:port?u=user&p=password&d=database
NC_DB=pg://postgres:5432?u=nocodb&p={{NOCODB_DB_PASS}}&d=nocodb_db

# NocoDB Public URL
NC_PUBLIC_URL=https://{{NOCODB_SUBDOMAIN}}.{{DOMAIN}}

# NocoDB Admin Credentials
NC_ADMIN_EMAIL={{ADMIN_EMAIL}}
NC_ADMIN_PASSWORD={{NOCODB_ADMIN_PASS}}

# Telemetry
NC_DISABLE_TELE=true

# OIDC via Authentik (only set if authentik is in foundation_services)
# NC_OIDC_ISSUER_URL=https://{{AUTHENTIK_SUBDOMAIN}}.{{DOMAIN}}/application/o/nocodb/
# NC_OIDC_CLIENT_ID={{NOCODB_OIDC_CLIENT_ID}}
# NC_OIDC_CLIENT_SECRET={{NOCODB_OIDC_CLIENT_SECRET}}
# NC_OIDC_AUTH_CALLBACK_URL=https://{{NOCODB_SUBDOMAIN}}.{{DOMAIN}}/api/v1/auth/oidc/callback
