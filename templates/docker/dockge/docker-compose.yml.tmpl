services:
  dockge:
    image: louislam/dockge:latest
    container_name: dockge
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{DATA_ROOT}}/data/dockge:/app/data
      - {{DATA_ROOT}}/docker:/opt/stacks
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:5001']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

networks:
  {{DOCKER_NET}}:
    external: true
