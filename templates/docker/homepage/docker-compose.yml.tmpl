services:
  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: homepage
    restart: unless-stopped
    volumes:
      - {{DATA_ROOT}}/data/homepage/config:/app/config
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:3000']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

networks:
  {{DOCKER_NET}}:
    external: true
