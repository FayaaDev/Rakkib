#!/usr/bin/env bash

set -Eeuo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"
  SOURCE_TARGET="$(readlink "$SOURCE")"
  if [[ "$SOURCE_TARGET" == /* ]]; then
    SOURCE="$SOURCE_TARGET"
  else
    SOURCE="${SOURCE_DIR}/${SOURCE_TARGET}"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd -P)"

# shellcheck source=../lib/common.sh
. "${REPO_DIR}/lib/common.sh"

AGENT_MODE="${RAKKIB_AGENT:-auto}"
PRINT_PROMPT_ONLY=false

usage() {
  cat <<'USAGE'
Usage: rakkib <command> [options]

Commands:
  init         Run diagnostics and launch or print the agent prompt
  doctor       Run host diagnostics
  auth         Check sudo readiness
  prompt       Print the installer prompt
  privileged   Run a small allowlisted root-only helper action
  uninstall    Remove the user-scoped rakkib command shim
  version      Print version information

Run `rakkib <command> --help` for command-specific options.
USAGE
}

init_usage() {
  cat <<'USAGE'
Usage: rakkib init [--agent <auto|opencode|claude|codex|none>] [--no-agent]
                   [--print-prompt]

Runs the unprivileged Rakkib orchestration flow. On Linux, this command should
run as your normal admin user. Privileged setup happens later through explicit
sudo commands after Phase 6 confirmation.
USAGE
}

auth_usage() {
  cat <<'USAGE'
Usage: rakkib auth sudo

Validates sudo for this terminal with sudo -v. Rakkib never stores your sudo
password; sudo manages its own timestamp cache according to system policy.
USAGE
}

privileged_usage() {
  cat <<'USAGE'
Usage: sudo rakkib privileged <check|ensure-layout|fix-repo-owner> [options]

Root-only helper actions:
  check                Verify the helper is running as root
  ensure-layout        Create the base Rakkib data directories
  fix-repo-owner       Assign the repo back to the admin user

Options:
  --state <path>       State file path, default: .fss-state.yaml
  --data-root <path>   Data root override, default from state or /srv
  --admin-user <user>  Admin user override, default from state or SUDO_USER
  --repo-dir <path>    Repo path for fix-repo-owner, default: current repo
USAGE
}

uninstall_usage() {
  cat <<'USAGE'
Usage: rakkib uninstall

Removes the user-scoped rakkib command shim at ~/.local/bin/rakkib and the
managed Rakkib PATH block from ~/.bashrc when present.

This does not delete the Rakkib repository, deployed services, Docker data,
or any target-machine configuration created after install confirmation.
USAGE
}

rerun_command() {
  printf 'curl -fsSL https://raw.githubusercontent.com/FayaaDev/Rakkib/Simplify/install.sh | bash\n'
}

agent_prompt() {
  cat <<'PROMPT'
Read AGENT_PROTOCOL.md first.

Use this repo as the installer.
Ask me the question files in order.
Record answers in .fss-state.yaml.
Do not write outside the repo until Phase 6 (questions/06-confirm.md).
Run the agent as the normal admin user. On Linux, do not run the full agent session as root; after confirmation, request sudo only for specific privileged setup actions.
For privileged commands, use sudo -n so expired authorization fails fast instead of hanging for a password inside the agent session.
After confirmation, execute the numbered files in steps/ in order. Run docs/runbooks/restore-test.md only if restore testing is explicitly requested.
Stop on any failed Verify block and fix it before continuing.
PROMPT
}

print_agent_prompt() {
  cat <<EOF

Rakkib is ready for the agent-driven install flow.

Repo path:
  ${REPO_DIR}

Bootstrap entrypoint:
  $(rerun_command)

Paste this prompt if your agent was not launched automatically:

--- PROMPT START ---
$(agent_prompt)
--- PROMPT END ---
EOF
}

ensure_opencode_on_path() {
  command_exists opencode && return 0

  local candidate sudo_home
  local candidates=("${HOME}/.opencode/bin" "${HOME}/.local/bin" "/root/.opencode/bin")
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    sudo_home="$(getent passwd "$SUDO_USER" 2>/dev/null | cut -d: -f6 || true)"
    if [[ -n "$sudo_home" ]]; then
      candidates+=("${sudo_home}/.opencode/bin" "${sudo_home}/.local/bin")
    fi
  fi

  for candidate in "${candidates[@]}"; do
    if [[ -x "${candidate}/opencode" ]]; then
      export PATH="${candidate}:${PATH}"
      return 0
    fi
  done

  return 1
}

select_agent() {
  local candidate

  case "$AGENT_MODE" in
    auto)
      ensure_opencode_on_path || true
      for candidate in opencode claude codex; do
        if command_exists "$candidate"; then
          printf '%s\n' "$candidate"
          return 0
        fi
      done
      return 1
      ;;
    opencode|claude|codex)
      if [[ "$AGENT_MODE" == "opencode" ]]; then
        ensure_opencode_on_path || die "requested agent is not installed or not on PATH: ${AGENT_MODE}"
      else
        command_exists "$AGENT_MODE" || die "requested agent is not installed or not on PATH: ${AGENT_MODE}"
      fi
      printf '%s\n' "$AGENT_MODE"
      ;;
    print|none)
      return 2
      ;;
    *)
      die "unsupported agent: ${AGENT_MODE}; expected auto, opencode, claude, codex, or none"
      ;;
  esac
}

offer_install_opencode() {
  local answer

  if ensure_opencode_on_path; then
    return 0
  fi
  if [[ ! -r /dev/tty || ! -w /dev/tty ]]; then
    warn "No supported AI agent found on PATH: opencode, claude, codex."
    return 1
  fi

  printf 'No supported AI agent found on PATH: opencode, claude, codex.\n' > /dev/tty
  printf 'Install OpenCode now? y/N ' > /dev/tty
  IFS= read -r answer < /dev/tty || return 1
  case "$answer" in
    y|Y)
      if ensure_opencode_on_path; then
        return 0
      fi
      log "Installing OpenCode"
      curl -fsSL https://opencode.ai/install | bash
      hash -r 2>/dev/null || true
      ensure_opencode_on_path
      ;;
    *)
      return 1
      ;;
  esac
}

launch_agent_with_prompt() {
  local prompt="$1"
  local agent
  if agent="$(select_agent)"; then
    :
  elif [[ "$AGENT_MODE" == "auto" ]] && offer_install_opencode; then
    agent="opencode"
  else
    return 1
  fi

  if [[ ! -r /dev/tty ]]; then
    warn "No interactive /dev/tty is available; cannot launch ${agent} safely."
    return 1
  fi
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    warn "Launching the full AI agent as root is not recommended. Re-run as your normal admin user unless you are intentionally debugging."
  fi

  log "Launching ${agent} from ${REPO_DIR}"
  cd "$REPO_DIR"
  case "$agent" in
    opencode) opencode . --prompt "$prompt" < /dev/tty ;;
    claude) claude "$prompt" < /dev/tty ;;
    codex) codex "$prompt" < /dev/tty ;;
  esac
}

run_doctor() {
  local doctor="${REPO_DIR}/scripts/rakkib-doctor"
  [[ -x "$doctor" ]] || die "doctor script is missing or not executable: ${doctor}"

  log "Running Rakkib doctor"
  "$doctor" --state "${REPO_DIR}/.fss-state.yaml" || warn "Doctor reported failures. This can be normal before Step 00 installs Docker; review the report before proceeding."
}

ensure_tooling() {
  command_exists git || die "git is required. Install git, then rerun Rakkib."
  command_exists curl || warn "curl is not installed; install it before Cloudflare and download-heavy steps."
}

parse_init_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --no-agent)
        AGENT_MODE="print"
        shift
        ;;
      --print-prompt)
        AGENT_MODE="print"
        PRINT_PROMPT_ONLY=true
        shift
        ;;
      --agent)
        [[ "$#" -ge 2 ]] || die "missing value for --agent"
        AGENT_MODE="$2"
        shift 2
        ;;
      -h|--help)
        init_usage
        exit 0
        ;;
      *)
        die "unknown init argument: $1"
        ;;
    esac
  done
}

cmd_init() {
  parse_init_args "$@"
  detect_platform
  ensure_tooling

  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    warn "Rakkib init is designed to run unprivileged. Root should be used only for repair/debug sessions."
  fi
  run_doctor
  if [[ "$PRINT_PROMPT_ONLY" == true || "$AGENT_MODE" == "print" || "$AGENT_MODE" == "none" ]]; then
    print_agent_prompt
  elif ! launch_agent_with_prompt "$(agent_prompt)"; then
    print_agent_prompt
  fi
}

cmd_doctor() {
  local doctor="${REPO_DIR}/scripts/rakkib-doctor"
  [[ -x "$doctor" ]] || die "doctor script is missing or not executable: ${doctor}"
  exec "$doctor" "$@"
}

cmd_auth() {
  local topic="${1:-}"
  shift || true

  case "$topic" in
    sudo)
      if [[ "$#" -gt 0 ]]; then
        die "unknown sudo auth option: $1"
      fi
      if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
        log "Already running as root; no sudo validation needed."
        return 0
      fi
      command_exists sudo || die "sudo is required for privileged setup actions on Linux."
      log "Validating sudo for this terminal. Rakkib will not store your password."
      if [[ -r /dev/tty ]]; then
        sudo -v < /dev/tty
      else
        sudo -v
      fi
      log "Sudo is ready for this terminal according to your system sudo policy."
      ;;
    -h|--help|'')
      auth_usage
      ;;
    *)
      die "unknown auth topic: ${topic}"
      ;;
  esac
}

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    die "this helper must be run with sudo or from a root shell"
  fi
}

resolve_admin_user() {
  local state_file="$1"
  local explicit_user="$2"
  local user=""

  if [[ -n "$explicit_user" ]]; then
    printf '%s' "$explicit_user"
    return 0
  fi
  user="$(state_value "$state_file" admin_user 2>/dev/null || true)"
  if [[ -n "$user" ]]; then
    printf '%s' "$user"
    return 0
  fi
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    printf '%s' "$SUDO_USER"
    return 0
  fi

  return 1
}

cmd_privileged() {
  local action="${1:-}"
  shift || true

  case "$action" in
    -h|--help|'')
      privileged_usage
      return 0
      ;;
  esac

  require_root

  local state_file="${REPO_DIR}/.fss-state.yaml"
  local data_root=""
  local admin_user=""
  local repo_dir="$REPO_DIR"

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --state)
        [[ "$#" -ge 2 ]] || die "missing value for --state"
        state_file="$2"
        shift 2
        ;;
      --data-root)
        [[ "$#" -ge 2 ]] || die "missing value for --data-root"
        data_root="$2"
        shift 2
        ;;
      --admin-user)
        [[ "$#" -ge 2 ]] || die "missing value for --admin-user"
        admin_user="$2"
        shift 2
        ;;
      --repo-dir)
        [[ "$#" -ge 2 ]] || die "missing value for --repo-dir"
        repo_dir="$2"
        shift 2
        ;;
      *)
        die "unknown privileged option: $1"
        ;;
    esac
  done

  case "$action" in
    check)
      log "Privileged helper is running as root."
      ;;
    ensure-layout)
      if [[ -z "$data_root" ]]; then
        data_root="$(state_value "$state_file" data_root 2>/dev/null || true)"
      fi
      [[ -n "$data_root" ]] || data_root="/srv"
      admin_user="$(resolve_admin_user "$state_file" "$admin_user")" || die "admin user is required; pass --admin-user or record admin_user in state"

      log "Creating Rakkib layout under ${data_root}"
      mkdir -p \
        "$data_root" \
        "$data_root/docker" \
        "$data_root/data" \
        "$data_root/apps/static" \
        "$data_root/backups" \
        "$data_root/MDs"
      chown -R "${admin_user}:" \
        "$data_root/docker" \
        "$data_root/data" \
        "$data_root/apps" \
        "$data_root/backups" \
        "$data_root/MDs"
      ;;
    fix-repo-owner)
      admin_user="$(resolve_admin_user "$state_file" "$admin_user")" || die "admin user is required; pass --admin-user or record admin_user in state"
      [[ -d "$repo_dir" ]] || die "repo directory does not exist: ${repo_dir}"
      log "Assigning ${repo_dir} to ${admin_user}"
      chown -R "${admin_user}:" "$repo_dir"
      ;;
    *)
      die "unknown privileged action: ${action}"
      ;;
  esac
}

cmd_uninstall() {
  local target="${HOME}/.local/bin/rakkib"
  local profile="${HOME}/.bashrc"
  local marker="# Added by Rakkib: user-local bin on PATH"
  local tmp

  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    uninstall_usage
    return 0
  fi
  if [[ "$#" -gt 0 ]]; then
    die "unknown uninstall option: $1"
  fi

  if [[ -L "$target" ]]; then
    rm "$target"
    log "Removed rakkib CLI shim at ${target}"
  elif [[ -e "$target" ]]; then
    warn "Not removing ${target} because it is not a symlink. Remove it manually if you own it."
  else
    log "No rakkib CLI shim found at ${target}"
  fi

  if [[ -f "$profile" ]] && grep -Fq "$marker" "$profile"; then
    tmp="$(mktemp)"
    awk -v marker="$marker" '
      $0 == marker { skipping = 1; next }
      skipping && $0 == "esac" { skipping = 0; next }
      !skipping { print }
    ' "$profile" > "$tmp"
    cp "$tmp" "$profile"
    rm -f "$tmp"
    log "Removed managed Rakkib PATH block from ${profile}"
  else
    log "No managed Rakkib PATH block found in ${profile}"
  fi

  cat <<'EOF'

Rakkib CLI shim uninstall is complete.

If this terminal still resolves rakkib, refresh your shell command cache or open a new terminal:
  hash -r
EOF
}

cmd_version() {
  local git_ref="unknown"
  if command_exists git && git -C "$REPO_DIR" rev-parse --short HEAD >/dev/null 2>&1; then
    git_ref="$(git -C "$REPO_DIR" rev-parse --short HEAD)"
  fi
  printf 'rakkib cli: dev\nrepo: %s\n' "$git_ref"
}

main() {
  local command="${1:-}"
  if [[ "$#" -gt 0 ]]; then
    shift
  fi

  case "$command" in
    init) cmd_init "$@" ;;
    doctor) cmd_doctor "$@" ;;
    auth) cmd_auth "$@" ;;
    prompt) print_agent_prompt ;;
    privileged) cmd_privileged "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h|'') usage ;;
    *) die "unknown command: ${command}" ;;
  esac
}

main "$@"
