# NocoDB Database Connection
# Format: pg://host:port?u=user&p=password&d=database
NC_DB=pg://postgres:5432?u=nocodb&p=nocodb-db-pass&d=nocodb_db

# NocoDB Public URL
NC_PUBLIC_URL=https://data.example.com

# NocoDB Admin Credentials
NC_ADMIN_EMAIL=admin@example.com
NC_ADMIN_PASSWORD=nocodb-admin-pass

# Telemetry
NC_DISABLE_TELE=true

# OIDC via Authentik (only set if authentik is selected)

NC_OIDC_ISSUER_URL=https://auth.example.com/application/o/nocodb/
NC_OIDC_CLIENT_ID=nocodb-oidc-client-id
NC_OIDC_CLIENT_SECRET=nocodb-oidc-client-secret
NC_OIDC_AUTH_CALLBACK_URL=https://data.example.com/api/v1/auth/oidc/callback
