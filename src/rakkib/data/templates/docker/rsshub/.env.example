# RSSHub environment
# Docs: https://docs.rsshub.app/deploy/

# Core
PORT=1200
NODE_ENV=production

# Cache (Redis)
REDIS_URL=redis://rsshub-redis:6379/

# Optional: headless browser support for some routes
PUPPETEER_WS_ENDPOINT=ws://rsshub-browserless:3000

# Optional: keep memory usage in check
# CACHE_EXPIRE=600
