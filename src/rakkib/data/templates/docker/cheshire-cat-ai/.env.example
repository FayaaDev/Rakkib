# Cheshire Cat AI
# Docs: https://github.com/cheshire-cat-ai/core

# Timezone inside the container
CCAT_TIMEZONE=UTC

# Public host/protocol settings for reverse-proxied deployments
{% if EXPOSURE_MODE == "cloudflare" %}
CCAT_CORE_HOST={{CHESHIRE_CAT_AI_SUBDOMAIN}}.{{DOMAIN}}
CCAT_CORE_USE_SECURE_PROTOCOLS=true
CCAT_HTTPS_PROXY_MODE=true
CCAT_CORS_ALLOWED_ORIGINS=https://{{CHESHIRE_CAT_AI_SUBDOMAIN}}.{{DOMAIN}}
{% else %}
CCAT_CORE_HOST={{LAN_IP | default('127.0.0.1', true)}}
CCAT_CORE_USE_SECURE_PROTOCOLS=false
CCAT_HTTPS_PROXY_MODE=false
CCAT_CORS_ALLOWED_ORIGINS=http://{{LAN_IP | default('127.0.0.1', true)}}:13023
{% endif %}

# Optional API protection
# CCAT_API_KEY=
# CCAT_API_KEY_WS=
