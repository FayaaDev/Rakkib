# transfer.sh configuration
# Rakkib intentionally leaves uploads unauthenticated for transfer.sh CLI/API compatibility.
# Uploads are stored locally and purged after 14 days by default.
EMAIL_CONTACT={{ADMIN_EMAIL}}
TRANSFER_PURGE_DAYS=14
TRANSFER_PURGE_INTERVAL=1
TRANSFER_MAX_UPLOAD_SIZE_KB=1048576
