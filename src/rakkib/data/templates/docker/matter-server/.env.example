# Matter Server environment file
#
# Notes:
# - Matter Server is a WebSocket controller on host port 5580, not a browser UI.
# - The compose template uses host networking because Matter relies on mDNS and
#   IPv6 link-local multicast on the same LAN as the devices/border routers.

MATTER_SERVER_IMAGE=ghcr.io/matter-js/python-matter-server:stable
