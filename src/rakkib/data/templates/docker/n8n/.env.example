# n8n Database Configuration
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_db
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD={{N8N_DB_PASS}}

# n8n Instance Configuration
{% if EXPOSURE_MODE == "cloudflare" %}
N8N_HOST={{N8N_SUBDOMAIN}}.{{DOMAIN}}
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://{{N8N_SUBDOMAIN}}.{{DOMAIN}}/
{% else %}
N8N_HOST={{LAN_IP | default('127.0.0.1', true)}}
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://{{LAN_IP | default('127.0.0.1', true)}}:13004/
{% endif %}
GENERIC_TIMEZONE={{TZ}}
N8N_PROXY_HOPS=1

# n8n Encryption Key (CRITICAL - DO NOT CHANGE after first run or data will be lost)
N8N_ENCRYPTION_KEY={{N8N_ENCRYPTION_KEY}}

# Security: Enable all nodes (remove default blocks)
