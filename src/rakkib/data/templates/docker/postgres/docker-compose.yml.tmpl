services:
  postgres:
    image: pgvector/pgvector:pg16
    container_name: postgres
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - {{DATA_ROOT}}/data/postgres/data:/var/lib/postgresql/data
      - {{DATA_ROOT}}/docker/postgres/init-scripts:/docker-entrypoint-initdb.d:ro
      - {{DATA_ROOT}}/backups/postgres:/backups
    networks:
      - {{DOCKER_NET}}
    ports:
      - "127.0.0.1:5432:5432"

networks:
  {{DOCKER_NET}}:
    external: true
