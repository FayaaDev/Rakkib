services:
  uptime-kuma:
    image: louislam/uptime-kuma:latest
    container_name: uptime-kuma
    restart: unless-stopped
    volumes:
      - {{DATA_ROOT}}/data/uptime-kuma:/app/data
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      test: ['CMD', 'extra/healthcheck']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

networks:
  {{DOCKER_NET}}:
    external: true
