services:
  gladys-assistant:
    image: ${GLADYS_ASSISTANT_IMAGE:-gladysassistant/gladys:v4}
    container_name: gladys-assistant
    restart: unless-stopped
    privileged: true
    cgroup: host
    env_file:
      - .env
    logging:
      driver: json-file
      options:
        max-size: 10m
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{DATA_ROOT}}/data/gladys-assistant:/var/lib/gladysassistant
      - /dev:/dev
      - /run/udev:/run/udev:ro
    networks:
      - {{DOCKER_NET}}

networks:
  {{DOCKER_NET}}:
    external: true
