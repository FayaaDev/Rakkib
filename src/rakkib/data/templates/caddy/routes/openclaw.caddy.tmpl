# OpenClaw AI assistant gateway — protected by Authentik forward auth
	@openclaw host {{OPENCLAW_SUBDOMAIN}}.{{DOMAIN}}
	handle @openclaw {
		forward_auth authentik-server:9000 {
			uri /outpost.goauthentik.io/auth/caddy
			copy_headers X-authentik-username X-authentik-groups X-authentik-email X-authentik-uid
		}
		reverse_proxy {{HOST_GATEWAY}}:18789 {
			header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
			header_up X-Real-IP {http.request.header.CF-Connecting-IP}
			header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
		}
	}